---
import Hero from '../components/Hero.jsx';
import portrait from '../assets/yulong-liu-portrait.jpeg';
import analyticsSnapshot from '../data/analytics-snapshot.json';

const normalizedBase = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
const withBase = (path) => `${normalizedBase}${path.replace(/^\/+/, '')}`;
const analyticsSiteUrl = 'https://yulong.goatcounter.com';
const analyticsCountEndpoint = `${analyticsSiteUrl}/count`;

const formatNumber = (value) =>
	typeof value === 'number' ? new Intl.NumberFormat('en-US').format(value) : '—';

const formatSnapshotDate = (value) => {
	if (!value) return 'Waiting for first snapshot';
	return new Intl.DateTimeFormat('en-US', {
		month: 'short',
		day: 'numeric',
		year: 'numeric',
		hour: 'numeric',
		minute: '2-digit'
	}).format(new Date(value));
};

const getCountryFlag = (code) => {
	const normalized = (code || '').trim().toUpperCase();
	if (!/^[A-Z]{2}$/.test(normalized)) return '';
	return [...normalized]
		.map((letter) => String.fromCodePoint(letter.charCodeAt(0) + 127397))
		.join('');
};

const analyticsCountries = (analyticsSnapshot.countries || []).map((country) => ({
	...country,
	flag: getCountryFlag(country.code)
}));
const pageBackdropUrl = withBase('/backgrounds/adobe-stock-653911900.jpeg');

function emphasizeAuthor(authors) {
	return authors.replaceAll(
		'Yulong Liu',
		'<strong class="author-highlight">Yulong Liu</strong><span class="author-star" aria-hidden="true">*</span>'
	);
}

const navItems = [
	{ label: 'About', href: '#about' },
	{ label: 'Research', href: '#research' },
	{ label: 'Publications', href: '#publications' },
	{ label: 'Education', href: '#education' },
	{ label: 'Awards', href: '#awards' },
	{ label: 'Talks', href: '#talks' },
	{ label: 'Contact', href: '#contact' }
];

const focusAreas = ['Computational mechanics', 'Implicit neural representation', 'Poromechanics'];

const researchAreas = [
	{
		title: 'Computational mechanics',
		body: 'Developing deformation, damage, and fracture models for geomaterials within the MOOSE finite element framework.'
	},
	{
		title: 'Implicit neural representation',
		body: 'Continuous neural representations, physics-informed neural networks, and operator-learning surrogates for geometry-aware, physics-aware prediction, with growing interest in homogenization theory and physics-aware INR methods.'
	},
	{
		title: 'Poromechanics',
		body: 'Mechanics and transport in porous subsurface media, with a focus on poromechanics and multiscale transport.'
	}
];

const publications = [
	{
		year: '2026',
		type: 'Preprint',
		title: 'CodeMOOSE: Multi-Agent Collaborative Framework for Multiphysics MOOSE Language',
		authors: 'Yulong Liu, Zhenghan Song',
		venue: 'Preprint, January 2026',
		note: 'Open-source release in preparation.',
		href: null,
		linkLabel: null
	},
	{
		year: '2026',
		type: 'Conference paper',
		title:
			'Operator Learning Surrogate Modeling of Hydraulically Fractured Geothermal Injection-Production Systems: A Cornell Case Study',
		authors: 'Yulong Liu, Jonah Botvinick-Greenhouse, Yunan Yang, Chloé Arson',
		venue: 'ARMA 2026, Tucson',
		href: 'https://scholar.google.com/scholar?q=Operator+Learning+Surrogate+Modeling+of+Hydraulically+Fractured+Geothermal+Injection-Production+Systems:+A+Cornell+Case+Study',
		linkLabel: 'Find in Scholar'
	},
	{
		year: '2026',
		type: 'Preprint',
		title: 'A Physics-Informed Neural Network for Modeling Pressurized Cavities of Arbitrary Smooth Shape Embedded in Heterogeneous Rock',
		authors: 'Yulong Liu, Chloé Arson',
		venue: 'Research Square preprint',
		note: 'Currently under review.',
		href: 'https://doi.org/10.21203/rs.3.rs-8492281/v1',
		linkLabel: 'Read preprint'
	},
	{
		year: '2026',
		type: 'Journal article',
		title: 'Numerical assessment of plasticity development and energy expenditure of ant-like microtunnelling',
		authors: 'M. Belachew, Yulong Liu, J. D. Frost, Chloé Arson',
		venue: 'Tunnelling and Underground Space Technology, 172, 107501',
		href: 'https://doi.org/10.1016/j.tust.2026.107501',
		linkLabel: 'Open journal page'
	},
	{
		year: '2025',
		type: 'Conference paper',
		title: 'Physics-informed neural network surrogate modeling of pressurized cavity in homogeneous and bilayered media',
		authors: 'Yulong Liu, Chloé Arson',
		venue: 'ARMA US Rock Mechanics/Geomechanics Symposium, D022S018R006',
		href: 'https://scholar.google.com/scholar?q=Physics-informed+neural+network+surrogate+modeling+of+pressurized+cavity+in+homogeneous+and+bilayered+media',
		linkLabel: 'Find in Scholar'
	}
];

const education = [
	{
		institution: 'Cornell University',
		degree: 'Ph.D. student in Earth Sciences',
		meta: '2024 - Present · Ithaca, New York',
		detail: 'Department of Earth and Atmospheric Sciences · GPA 3.88 / 4.3'
	},
	{
		institution: 'Northeastern University',
		degree: 'B.S. in Mining Engineering',
		meta: '2020 - 2024 · Shenyang, China',
		detail: 'College of Engineering · GPA 3.94 / 4.5'
	}
];

const awards = [
	'2025 · Estwing Hammer Award, outstanding EAS graduate student of 2024',
	'2024 · Outstanding Thesis, outstanding undergraduate thesis',
	'2024 · National Scholarship, most outstanding student in the university',
	'2023 · First Class Scholarship',
	'2022 · Autumn Scholarship and Golden Seed Scholarship'
];

const service = [
	'Reviewer, Rock Mechanics and Rock Engineering',
	'Reviewer, International Conference on Artificial Neural Networks 2026'
];

const talks = [
	{
		type: 'Invited seminar',
		title:
			'A Physics-Informed Neural Network for Modeling Pressurized Cavities of Arbitrary Smooth Shape Embedded in Heterogeneous Rock',
		venue: 'Southwest Petroleum University seminar series, Chengdu, China',
		date: 'December 31, 2025'
	}
];

const profileFacts = [
	{ label: 'Program', value: 'Ph.D. in Earth Sciences' },
	{
		label: 'Advisor',
		value: 'Chloé Arson',
		href: 'https://arsonlab.engineering.cornell.edu/'
	},
	{ label: 'Focus', value: 'Computational mechanics · INR · Poromechanics' },
	{ label: 'Base', value: 'Ithaca, New York' },
	{ label: 'Email', value: 'yl3825@cornell.edu' }
];

const externalLinks = [
	{
		label: 'Google Scholar',
		href: 'https://scholar.google.com/citations?user=0CV0lsQAAAAJ&hl=en'
	},
	{
		label: 'LinkedIn',
		href: 'https://www.linkedin.com/in/yulong-liu-19451a322/'
	},
	{
		label: 'GitHub',
		href: 'https://github.com/Yulongggggg'
	},
	{
		label: 'Cornell email',
		href: 'mailto:yl3825@cornell.edu'
	}
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
			<meta
				name="description"
				content="Yulong Liu is a Ph.D. student in Earth Sciences at Cornell University, working across computational mechanics, implicit neural representation, poromechanics, and subsurface energy systems."
			/>
				<title>Yulong Liu | Personal Website</title>
				<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
			<link rel="preconnect" href="https://fonts.googleapis.com" />
			<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
				href="https://fonts.googleapis.com/css2?family=Lora:wght@500;600;700&family=Merriweather:wght@700;900&family=Manrope:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,400;500;600&display=swap"
				rel="stylesheet"
			/>
			{analyticsCountEndpoint ? (
				<script async src="https://gc.zgo.at/count.js" data-goatcounter={analyticsCountEndpoint}></script>
			) : null}
		</head>
			<body style={`--page-photo-url: url("${pageBackdropUrl}")`}>
			<Hero
				prefix="Hi, I'm"
				text="YULONG LIU"
				subtitle="Ph.D. student in Earth Sciences at Cornell University"
				client:load
			/>

				<nav class="site-nav" aria-label="Section navigation">
				<div class="site-nav__inner">
					{navItems.map((item) => (
						<a href={item.href} class="site-nav__link">
							{item.label}
						</a>
					))}
					<button type="button" class="site-nav__button" data-analytics-open>
						Analytics
					</button>
				</div>
			</nav>

		<main class="page-shell">
				<section class="intro-section focus-section" id="about">
					<div class="intro-body">
						<div class="intro-side" data-reveal="left">
							<div class="portrait-media">
								<img src={portrait.src} alt="Portrait of Yulong Liu" loading="eager" />
							</div>
						</div>

						<div class="intro-copy" data-reveal="right" data-reveal-delay="80">
							<div class="intro-main">
								<p class="eyebrow" data-hero-name-target>Yulong Liu</p>
								<h1>Ph.D. student in Earth Sciences at Cornell University.</h1>
								<p class="lead">
									I work across computational mechanics, implicit neural representation,
									poromechanics, and subsurface energy systems, with a focus on surrogate modeling
									for coupled multiphysics problems in Earth science. I am also increasingly interested in
									homogenization theory and physics-aware implicit neural representations.
								</p>
							</div>

							<div class="intro-actions">
								<div class="inline-tags">
									{focusAreas.map((item) => (
										<span>{item}</span>
									))}
								</div>

								<div class="inline-links">
									{externalLinks.map((link) => (
										<a
											href={link.href}
											target={link.href.startsWith('http') ? '_blank' : undefined}
											rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
										>
											{link.label}
										</a>
									))}
								</div>
							</div>

							<dl class="meta-list meta-list--intro">
								{profileFacts.map((fact) => (
									<div class="meta-row">
										<dt>{fact.label}</dt>
										<dd>
											{fact.href ? (
												<a href={fact.href} target="_blank" rel="noreferrer" class="meta-link">
													{fact.value}
												</a>
											) : (
												fact.value
											)}
										</dd>
									</div>
								))}
							</dl>
						</div>
					</div>
				</section>

			<section class="section-block focus-section" id="research">
				<div class="section-heading">
					<p class="section-kicker">Research</p>
					<h2>Current directions in my work.</h2>
				</div>

				<div class="line-list">
					{researchAreas.map((item, index) => (
						<article class="line-item" data-reveal="up" data-reveal-delay={String(index * 90)}>
							<p class="line-index">0{index + 1}</p>
							<div class="line-copy">
								<h3>{item.title}</h3>
								<p>{item.body}</p>
							</div>
						</article>
					))}
				</div>
			</section>

				<section class="section-block focus-section" id="publications">
					<div class="section-heading">
						<p class="section-kicker">Publications</p>
						<h2>Current publication list.</h2>
					</div>

						<ol class="publication-list">
								{publications.map((item, index) => (
									<li class="publication-item" data-reveal="up" data-reveal-delay={String(index * 90)}>
									<div class="publication-meta">
										<span>{item.year}</span>
										<span>{item.type}</span>
							</div>
								<div class="publication-copy">
									<h3>{item.title}</h3>
									<p class="publication-authors" set:html={emphasizeAuthor(item.authors)} />
									<p class="publication-venue">{item.venue}</p>
									{item.note ? <p class="publication-note">{item.note}</p> : null}
									{item.href && item.linkLabel ? (
										<a href={item.href} target="_blank" rel="noreferrer" class="text-link">
											{item.linkLabel}
										</a>
									) : null}
								</div>
							</li>
							))}
					</ol>

					<div class="results-gallery" data-reveal="up" data-reveal-delay="120">
						<figure
							class="results-card results-card--left"
							role="button"
							tabindex="0"
							data-results-open
							data-results-src={withBase('/research-results/fig11-1layer-30.png')}
							data-results-alt="Comparative field plots for displacement, stress, and error around a circular cavity."
							aria-label="Open enlarged research figure"
						>
							<img
								src={withBase('/research-results/fig11-1layer-30.png')}
								alt="Comparative field plots for displacement, stress, and error around a circular cavity."
								loading="lazy"
							/>
						</figure>
						<figure
							class="results-card results-card--top"
							role="button"
							tabindex="0"
							data-results-open
							data-results-src={withBase('/research-results/gr11-lrg.jpg')}
							data-results-alt="Stage-wise stress evolution figure from ant-like microtunnelling study."
							aria-label="Open enlarged research figure"
						>
							<img
								src={withBase('/research-results/gr11-lrg.jpg')}
								alt="Stage-wise stress evolution figure from ant-like microtunnelling study."
								loading="lazy"
							/>
						</figure>
						<figure
							class="results-card results-card--bottom"
							role="button"
							tabindex="0"
							data-results-open
							data-results-src={withBase('/research-results/generalization-1.png')}
							data-results-alt="Generalization comparison across fracture configurations."
							aria-label="Open enlarged research figure"
						>
							<img
								src={withBase('/research-results/generalization-1.png')}
								alt="Generalization comparison across fracture configurations."
								loading="lazy"
							/>
						</figure>
					</div>
				</section>

			<section class="section-block focus-section" id="education">
				<div class="section-heading">
					<p class="section-kicker">Education</p>
					<h2>Academic path.</h2>
				</div>

				<div class="row-list">
					{education.map((item, index) => (
						<article class="row-item" data-reveal="up" data-reveal-delay={String(index * 90)}>
							<div class="row-meta">
								<p>{item.meta}</p>
							</div>
							<div class="row-copy">
								<h3>{item.institution}</h3>
								<p class="row-title">{item.degree}</p>
								<p>{item.detail}</p>
							</div>
						</article>
					))}
				</div>
			</section>

			<section class="section-block focus-section" id="awards">
				<div class="section-heading">
					<p class="section-kicker">Awards & service</p>
					<h2>Recognition and academic contribution.</h2>
				</div>

				<div class="dual-stream">
					<div class="stream" data-reveal="left">
						<h3>Awards</h3>
						<ul class="plain-list">
							{awards.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</div>

					<div class="stream" data-reveal="right" data-reveal-delay="80">
						<h3>Academic service</h3>
						<ul class="plain-list">
							{service.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</div>
				</div>
			</section>

			<section class="section-block focus-section" id="talks">
				<div class="section-heading">
					<p class="section-kicker">Talks</p>
					<h2>Invited seminar.</h2>
				</div>

				<div class="row-list">
					{talks.map((talk, index) => (
						<article class="row-item" data-reveal="up" data-reveal-delay={String(index * 90)}>
							<div class="row-meta">
								<p>{talk.type}</p>
								<p>{talk.date}</p>
							</div>
							<div class="row-copy">
								<h3>{talk.title}</h3>
								<p>{talk.venue}</p>
							</div>
						</article>
					))}
				</div>
			</section>

			<footer class="section-block footer-block focus-section" id="contact">
				<div class="section-heading">
					<p class="section-kicker">Contact</p>
					<h2>Open to thoughtful research conversations<br />or collaboration.</h2>
				</div>

				<p class="footer-text">
					Reach me at <a href="mailto:yl3825@cornell.edu">yl3825@cornell.edu</a> or
					<a href="mailto:yulong.liuuu@gmail.com">yulong.liuuu@gmail.com</a>.
				</p>

				<div class="inline-links">
					{externalLinks.map((link) => (
						<a
							href={link.href}
							target={link.href.startsWith('http') ? '_blank' : undefined}
							rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
						>
							{link.label}
						</a>
					))}
				</div>
				</footer>
				</main>

				<div class="analytics-modal" data-analytics-modal hidden>
					<div class="analytics-modal__backdrop" data-analytics-close></div>
					<div class="analytics-modal__panel" role="dialog" aria-modal="true" aria-label="Visitor analytics">
						<div class="analytics-modal__header">
							<div>
								<p class="analytics-modal__eyebrow">Analytics</p>
								<h3>Visit overview and countries.</h3>
							</div>
							<button type="button" class="analytics-modal__close" data-analytics-close>
								Close
							</button>
						</div>

						{analyticsSnapshot.connected ? (
							<div class="analytics-panel">
								<div class="analytics-summary">
									<div class="analytics-card analytics-card--primary">
										<p class="analytics-card__label">Visits</p>
										<p class="analytics-card__value">
											{formatNumber(analyticsSnapshot.totalVisitors)}
										</p>
										<p class="analytics-card__note">All-time GoatCounter snapshot</p>
									</div>

									<div class="analytics-card">
										<p class="analytics-card__label">Countries</p>
										<p class="analytics-card__value">{formatNumber(analyticsCountries.length)}</p>
										<p class="analytics-card__note">Places where visits have come from</p>
									</div>

									<div class="analytics-card analytics-card--meta">
										<p class="analytics-card__label">Updated</p>
										<p class="analytics-card__value analytics-card__value--small">
											{formatSnapshotDate(analyticsSnapshot.generatedAt)}
										</p>
										<p class="analytics-card__note">Refreshed automatically during deployment</p>
									</div>
								</div>

								<div class="analytics-country-block">
									<div class="analytics-country-block__header">
										<p class="analytics-country-block__eyebrow">Countries</p>
									</div>

									<ul class="analytics-country-list">
										{analyticsCountries.map((country) => (
											<li class="analytics-country-item">
												<span class="analytics-country-item__icon" aria-hidden="true">
													{country.flag || country.code?.slice(0, 1) || '•'}
												</span>
												<span class="analytics-country-item__name">{country.name}</span>
												<span class="analytics-country-item__count">
													{formatNumber(country.count)}
												</span>
											</li>
										))}
									</ul>
								</div>
							</div>
						) : (
							<div class="analytics-modal__empty">
								<p>
									This panel is ready, but the analytics snapshot has not been generated yet. Keep
									the GoatCounter counting script active, and add your GoatCounter API token as a
									GitHub Actions secret named `GOATCOUNTER_API_TOKEN` so deployment can fetch
									visitor totals and country data safely.
								</p>
								<p>
									The site already counts visits through GoatCounter. The only missing step is the
									private build-time secret for reading statistics. Use the official setup guide:
									<a href="https://www.goatcounter.com/help/start" target="_blank" rel="noreferrer">
										GoatCounter setup
									</a>
									and
									<a href="https://www.goatcounter.com/api.html" target="_blank" rel="noreferrer">
										API documentation
									</a>.
								</p>
							</div>
						)}
					</div>
				</div>

				<div class="results-lightbox" data-results-lightbox hidden>
					<button
						type="button"
						class="results-lightbox__backdrop"
						data-results-close
						aria-label="Close enlarged image"
					></button>
					<div class="results-lightbox__panel" role="dialog" aria-modal="true" aria-label="Research figure preview">
						<button type="button" class="results-lightbox__close" data-results-close>
							Close
						</button>
						<img class="results-lightbox__image" data-results-image src="" alt="" />
					</div>
				</div>

				<script is:inline>
					const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const revealElements = [...document.querySelectorAll('[data-reveal]')];
			const navLinks = [...document.querySelectorAll('.site-nav__link')];
			const analyticsOpen = document.querySelector('[data-analytics-open]');
			const analyticsModal = document.querySelector('[data-analytics-modal]');
			const analyticsClose = [...(analyticsModal?.querySelectorAll('[data-analytics-close]') || [])];
			const resultsTriggers = [...document.querySelectorAll('[data-results-open]')];
			const resultsLightbox = document.querySelector('[data-results-lightbox]');
			const resultsImage = resultsLightbox?.querySelector('[data-results-image]');
			const resultsClose = [...(resultsLightbox?.querySelectorAll('[data-results-close]') || [])];
					const sections = navLinks
						.map((link) => document.querySelector(link.getAttribute('href')))
						.filter(Boolean);
					const focusSections = [...document.querySelectorAll('.focus-section')];
					const portraitMedia = document.querySelector('.portrait-media');

					const openAnalytics = () => {
						if (!analyticsModal) return;
						analyticsModal.hidden = false;
						document.body.style.overflow = 'hidden';
						analyticsModal.querySelector('.analytics-modal__close')?.focus();
					};

					const closeAnalytics = () => {
						if (!analyticsModal || analyticsModal.hidden) return;
						analyticsModal.hidden = true;
						document.body.style.removeProperty('overflow');
						analyticsOpen?.focus();
					};

					const openResultsLightbox = (trigger) => {
						if (!resultsLightbox || !(resultsImage instanceof HTMLImageElement)) return;
						const { resultsSrc, resultsAlt } = trigger.dataset;
						if (!resultsSrc) return;

						resultsImage.src = resultsSrc;
						resultsImage.alt = resultsAlt || '';
						resultsLightbox.hidden = false;
						document.body.style.overflow = 'hidden';
						resultsLightbox.querySelector('.results-lightbox__close')?.focus();
					};

					const closeResultsLightbox = () => {
						if (!resultsLightbox || resultsLightbox.hidden) return;
						resultsLightbox.hidden = true;
						document.body.style.removeProperty('overflow');
						if (resultsImage instanceof HTMLImageElement) {
							resultsImage.removeAttribute('src');
							resultsImage.removeAttribute('alt');
						}
					};

			const setActiveSection = () => {
				const threshold = window.scrollY + window.innerHeight * 0.3;
				let currentId = sections[0]?.id;

				for (const section of sections) {
					if (section.offsetTop <= threshold) {
						currentId = section.id;
					}
				}

				for (const link of navLinks) {
					const isActive = link.getAttribute('href') === `#${currentId}`;
					link.classList.toggle('is-active', isActive);
				}
			};

			const updatePortraitShift = () => {
				if (!portraitMedia) return;
				const rect = portraitMedia.getBoundingClientRect();
				const shift = Math.max(-18, Math.min(18, (window.innerHeight * 0.58 - rect.top) * 0.05));
				portraitMedia.style.setProperty('--media-shift', `${shift.toFixed(2)}px`);
			};

			const updateSectionFocus = () => {
				if (reduceMotion) return;
				const focalPoint = window.innerHeight * 0.42;
				const range = window.innerHeight * 0.9;
				let focused = null;
				let smallestDistance = Infinity;
				const nearTop = window.scrollY < 48;
				const nearBottom =
					window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 48;

				for (const section of focusSections) {
					const rect = section.getBoundingClientRect();
					const center = rect.top + rect.height * 0.5;
					const distance = Math.abs(center - focalPoint);
					if (distance < smallestDistance) {
						smallestDistance = distance;
						focused = section;
					}
				}

				if (nearTop) {
					focused = focusSections[0];
				}

				if (nearBottom) {
					focused = focusSections[focusSections.length - 1];
				}

				for (const section of focusSections) {
					const rect = section.getBoundingClientRect();
					const center = rect.top + rect.height * 0.5;
					const distance = Math.abs(center - focalPoint);
					const normalized = Math.min(distance / range, 1);
					const isFocused = section === focused;
					const blur = normalized * 1.8;
					const opacity = 1 - normalized * 0.09;
					const scale = 1 - normalized * 0.006;
					const shift = (center < focalPoint ? -1 : 1) * normalized * 4;

					if (isFocused) {
						section.style.removeProperty('--section-blur');
						section.style.removeProperty('--section-opacity');
						section.style.removeProperty('--section-scale');
						section.style.removeProperty('--section-shift');
					} else {
						section.style.setProperty('--section-blur', `${blur.toFixed(2)}px`);
						section.style.setProperty('--section-opacity', opacity.toFixed(3));
						section.style.setProperty('--section-scale', scale.toFixed(3));
						section.style.setProperty('--section-shift', `${shift.toFixed(2)}px`);
					}

					section.classList.toggle('is-focused', isFocused);
					section.classList.toggle('is-dimmed', !isFocused);
				}
			};

			let ticking = false;
				const handleScroll = () => {
					if (ticking) return;
					ticking = true;
				requestAnimationFrame(() => {
					setActiveSection();
					updatePortraitShift();
					updateSectionFocus();
						ticking = false;
					});
				};

				if (!reduceMotion && 'IntersectionObserver' in window) {
				const observer = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (!entry.isIntersecting) continue;
							entry.target.classList.add('is-visible');
							observer.unobserve(entry.target);
						}
					},
					{ threshold: 0.14, rootMargin: '0px 0px -10% 0px' }
				);

				for (const element of revealElements) {
					const delay = element.dataset.revealDelay || '0';
					element.style.setProperty('--reveal-delay', `${delay}ms`);
					observer.observe(element);
				}

				window.addEventListener('scroll', handleScroll, { passive: true });
			} else {
				for (const element of revealElements) {
					element.classList.add('is-visible');
				}
			}

				setActiveSection();
				updatePortraitShift();
				updateSectionFocus();
				window.addEventListener('resize', handleScroll);
				analyticsOpen?.addEventListener('click', openAnalytics);
				for (const control of analyticsClose) {
					control.addEventListener('click', closeAnalytics);
				}
				for (const trigger of resultsTriggers) {
					trigger.addEventListener('click', () => openResultsLightbox(trigger));
					trigger.addEventListener('keydown', (event) => {
						if (event.key === 'Enter' || event.key === ' ') {
							event.preventDefault();
							openResultsLightbox(trigger);
						}
					});
				}
				for (const control of resultsClose) {
					control.addEventListener('click', closeResultsLightbox);
				}
				window.addEventListener('keydown', (event) => {
					if (event.key === 'Escape') {
						closeAnalytics();
						closeResultsLightbox();
					}
				});
			</script>
	</body>
